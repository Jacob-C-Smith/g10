{
    "name" : "g10 example",
    "version" : 
    {
        "major" : 1,
        "minor" : 0,
        "patch" : 0
    },
    "window" : 
    {
        "title" : "g10 example",
        "width" : 720,
        "height" : 720
    },
    "input" :
    {
        "name"              : "default input",
        "mouse sensitivity" : 1.0,
        "binds"             :
        {
            "FORWARD"      : [ "W" ],
            "BACKWARD"     : [ "S" ],
            "STRAFE LEFT"  : [ "A" ],
            "STRAFE RIGHT" : [ "D" ],
            "CAMERA UP"    : [ "UP" ],
            "CAMERA DOWN"  : [ "DOWN" ],
            "CAMERA LEFT"  : [ "LEFT" ],
            "CAMERA RIGHT" : [ "RIGHT" ],
            "CROUCH"       : [ "C" ],
            "PRONE"        : [ "LEFT SHIFT" ],
            "MOUSE LOCK"   : [ "M" ],
            "JUMP"         : [ "SPACE" ],
            "QUIT"         : [ "ESCAPE" ]
        }
    },
    "scene" : 
    {
        "name" : "scene",
        "entities" : 
        [
            {
                "name" : "entity",
                "pipeline" : "tbn",
                "color" : [ 1.0, 0.5, 0.5 ],
                "normal" : "assets/texture/pitch_normal.png",
                "texture" : "assets/texture/debug.png",
                "transform" :
                {
                    "location" : [ 0.0, 0.0, 0.0 ],
                    "rotation" : [ 0.0, 0.0, 0.0 ],
                    "scale"    : [ 1.0, 1.0, 1.0 ]
                },
                "geometry" : "assets/geometry/plane.json"
            },
            {
                "name" : "entity2",
                "pipeline" : "tbn",
                "color" : [ 1.0, 0.5, 0.5 ],
                "normal" : "assets/texture/pitch_normal.png",
                "texture" : "assets/texture/debug.png",
                "transform" :
                {
                    "location" : [ 0.0, 0.0, 0.0 ],
                    "rotation" : [ 0.0, 0.0, 0.0 ],
                    "scale"    : [ 1.0, 1.0, 1.0 ]
                },
                "geometry" : "assets/geometry/plane2.json"
            }
        ],
        "cameras" :
        [
            {
                "name" : "camera",
                "fov" : 45.0,
                "location" : [ 0.0, 0.0, 7.50 ],
                "orientation" : [ 0.0, 0.0, -1.0 ],
                "clip" :
                {
                    "near" : 0.1,
                    "far"  : 1000.0
                }
            }
        ]
    },
    "renderer" : 
    {
        "name"      : "renderer",
        "pipelines" :
        [
            "assets/pipeline/color.json",
            "assets/pipeline/uv.json",
            "assets/pipeline/normal.json",
            "assets/pipeline/tbn.json"
        ],
        "attachments" : 
        [
            {
                "name" : "OUTPUT",
                "type" : "framebuffer"
            },
            { 
                "name" : "color",
                "type" : "texture"
            },
            {
                "name" : "depth",
                "type" : "depth"
            }
        ],
        "passes" : 
        [
            {
                "name" : "gbuf",
                "framebuffer" : 
                { 
                    "clear" : [ 1.0, 1.0, 1.0, 0.0 ],
                    "color" : [ "OUTPUT" ],
                    "depth" : "depth"
                },
                "pipelines" : [ "color", "uv", "normal", "tbn" ]
            }
        ]
    }
}