{
    "name" : "lightspeed",
    "version" : 
    {
        "major" : 1,
        "minor" : 0,
        "patch" : 0
    },
    "window" : 
    {
        "title" : "lightspeed",
        "width" : 1280,
        "height" : 720
    },
    "scene" : 
    {
        "name" : "scene",
        "entities" : 
        [
            {
                "name" : "entity",
                "pipeline" : "tbn",
                "color" : [ 1.0, 0.5, 0.5 ],
                "normal" : "assets/texture/pitch_normal.png",
                "texture" : "assets/texture/debug_big.png",
                "transform" :
                {
                    "location" : [ 0.0, 0.0, 0.0 ],
                    "rotation" : [ 90.0, 180.0, 0.0 ],
                    "scale"    : [ 10.0, 10.0, 10.0 ]
                },
                "geometry" : "assets/geometry/plane.json"
            }
        ],
        "cameras" :
        [
            {
                "name" : "camera",
                "fov" : 45.0,
                "location" : [ 0.0, 1.0, 7.50 ],
                "orientation" : [ 0.0, 0.0, 1.0 ],
                "clip" :
                {
                    "near" : 0.1,
                    "far"  : 1000.0
                }
            }
        ]
    },
    "renderer" : 
    {
        "name"      : "renderer",
        "pipelines" :
        [
            "assets/pipeline/color.json",
            "assets/pipeline/uv.json",
            "assets/pipeline/normal.json",
            "assets/pipeline/tbn.json"
        ],
        "attachments" : 
        [
            {
                "name" : "OUTPUT",
                "type" : "framebuffer"
            },
            { 
                "name" : "color",
                "type" : "texture"
            },
            {
                "name" : "depth",
                "type" : "depth"
            }
        ],
        "passes" : 
        [
            {
                "name" : "gbuf",
                "framebuffer" : 
                { 
                    "clear" : [ 1.0, 1.0, 1.0, 0.0 ],
                    "color" : [ "OUTPUT" ],
                    "depth" : "depth"
                },
                "pipelines" : [ "color", "uv", "normal", "tbn" ]
            }
        ]
    }
}