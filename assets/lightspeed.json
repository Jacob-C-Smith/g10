{
    "name" : "lightspeed",
    "version" : 
    {
        "major" : 1,
        "minor" : 0,
        "patch" : 0
    },
    "window" : 
    {
        "title" : "lightspeed",
        "width" : 1280,
        "height" : 720
    },
    "input" :
    {
        "name"              : "default input",
        "mouse sensitivity" : 1.0,
        "binds"             :
        {
            "FORWARD"      : [ "W" ],
            "BACKWARD"     : [ "S" ],
            "STRAFE LEFT"  : [ "A" ],
            "STRAFE RIGHT" : [ "D" ],
            "CAMERA UP"    : [ "UP" ],
            "CAMERA DOWN"  : [ "DOWN" ],
            "CAMERA LEFT"  : [ "LEFT" ],
            "CAMERA RIGHT" : [ "RIGHT" ],
            "CROUCH"       : [ "C" ],
            "PRONE"        : [ "LEFT SHIFT" ],
            "MOUSE LOCK"   : [ "M" ],
            "JUMP"         : [ "SPACE" ],
            "QUIT"         : [ "ESCAPE" ]
        }
    },
    "scene" : "assets/scene/test room.json",
    "renderer" : 
    {
        "name"      : "renderer",
        "pipelines" :
        [
            "assets/pipeline/color.json",
            "assets/pipeline/uv.json",
            "assets/pipeline/normal.json",
            "assets/pipeline/tbn.json",
            "assets/pipeline/default.json"
        ],
        "attachments" : 
        [
            {
                "name" : "OUTPUT",
                "type" : "framebuffer"
            },
            {
                "name" : "depth",
                "type" : "depth"
            }
        ],
        "passes" : 
        [
            {
                "name" : "gbuf",
                "framebuffer" : 
                { 
                    "clear" : [ 1.0, 1.0, 1.0, 0.0 ],
                    "color" : [ "OUTPUT" ],
                    "depth" : "depth"
                },
                "pipelines" : [ "color", "uv", "normal", "tbn", "default" ]
            }
        ]
    }
}